---
import { ui, type Lang } from '../i18n'

interface Props {
  lang: Lang
}

const { lang } = Astro.props
const t = ui[lang].projects
---

<section id="projects">
  <div class="section__inner">
    <h2 class="section__title">{t.title}</h2>

    <div class="projects__grid">
      {t.items.map((project, i) => (
        <article class="project-card" data-index={i}>
          <div class="project-card__top">
            <div class="project-card__number">0{i + 1}</div>
            <span class="project-card__origin">{project.origin}</span>
          </div>

          <div class="project-card__body">
            <h3 class="project-card__name">{project.name}</h3>
            <p class="project-card__desc">{project.desc}</p>
          </div>

          <div class="project-card__footer">
            <div class="project-card__tags">
              {project.tags.map((tag) => (
                <span class="project-tag">{tag}</span>
              ))}
            </div>

            <a
              href={project.github}
              target="_blank"
              rel="noopener noreferrer"
              class="project-card__link"
              aria-label={`GitHub — ${project.name}`}
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
              </svg>
              GitHub
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="arrow">
                <path d="M7 17L17 7M17 7H7M17 7v10"/>
              </svg>
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  section {
    padding: 5rem 2rem;
  }

  .projects__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1rem;
    margin-top: 2.5rem;
  }

  .project-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 14px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: border-color 0.2s ease, transform 0.2s ease;
    position: relative;
    overflow: hidden;
  }

  .project-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s ease;
  }

  .project-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-3px);
  }

  .project-card:hover::before {
    transform: scaleX(1);
  }

  /* ── Top ── */
  .project-card__top {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .project-card__number {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-accent);
    opacity: 0.7;
  }

  .project-card__origin {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--color-text-secondary);
    background: var(--color-surface-2);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.2rem 0.65rem;
  }

  /* ── Body ── */
  .project-card__body {
    flex: 1;
  }

  .project-card__name {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: 0.6rem;
    line-height: 1.3;
  }

  .project-card__desc {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
  }

  /* ── Footer ── */
  .project-card__footer {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    border-top: 1px solid var(--color-border);
    padding-top: 0.875rem;
  }

  .project-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .project-tag {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--color-accent);
    background: rgba(var(--accent-rgb), 0.08);
    border: 1px solid rgba(var(--accent-rgb), 0.2);
    border-radius: 999px;
    padding: 0.18rem 0.6rem;
  }

  .project-card__link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.2s;
    width: fit-content;
  }

  .project-card__link:hover {
    color: var(--color-accent);
  }

  .project-card__link .arrow {
    transition: transform 0.2s;
  }

  .project-card__link:hover .arrow {
    transform: translate(2px, -2px);
  }

  @media (max-width: 640px) {
    .projects__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
